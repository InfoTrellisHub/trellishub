# Supabase (Settings -> API in your Supabase project)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Gmail App Password for info.trellishub@gmail.com (requires 2-Step Verification enabled)
GMAIL_USER=info.trellishub@gmail.com
GMAIL_APP_PASSWORD=

# Random long string used to sign session JWTs (admin + customer cookies)
JWT_SECRET=

# Google Cloud Console -> APIs & Services -> Credentials -> OAuth client ID (Web application)
GOOGLE_OAUTH_CLIENT_ID=

# Two developer admin logins (bcrypt hashes — see lib/hash-password.js helper script)
ADMIN_NAME_1=
ADMIN_PASSWORD_HASH_1=
ADMIN_NAME_2=
ADMIN_PASSWORD_HASH_2=

# Optional — only needed if your IP-geolocation provider requires a key at higher volume
GEO_API_KEY=

# Public base URL of the deployed site (used in emails, .ics-free booking confirmations, etc.)
SITE_URL=https://trellishub.vercel.app
